    <div
      class='protocol-grid'
      data-reveal
    >
      <article>
        <span>01 / DATASET</span><h3 data-i18n='protocol.gesture'>
          {t['protocol.gesture']}
        </h3><p data-i18n='protocol.gesture.body'>
