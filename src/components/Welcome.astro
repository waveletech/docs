<script>
  const mobileIndex = document.querySelector<HTMLSelectElement>(
    '[data-mobile-index]',
  )
  mobileIndex?.addEventListener('change', () => {
    if (mobileIndex.value) window.location.hash = mobileIndex.value
    mobileIndex.value = ''
  })

  const header = document.querySelector<HTMLElement>('[data-header]')
  const progress = document.querySelector<HTMLElement>('[data-scroll-progress]')
  const floatingIndex = document.querySelector<HTMLElement>(
    '[data-floating-index]',
  )
  const floatingProgress = document.querySelector<HTMLElement>(
    '[data-floating-progress]',
  )
  const progressNodes = Array.from(
    document.querySelectorAll<HTMLAnchorElement>('[data-progress-node]'),
  )
  const hero = document.querySelector<HTMLElement>('.hero')
  const updateScroll = () => {
    const max = Math.max(
      1,
      document.documentElement.scrollHeight - window.innerHeight,
    )
    const ratio = Math.min(1, window.scrollY / max)
    progress?.style.setProperty('transform', `scaleX(${ratio})`)
    floatingProgress?.style.setProperty('transform', `scaleX(${ratio})`)
    header?.classList.toggle('is-scrolled', window.scrollY > 24)
    const indexVisible =
      window.scrollY > Math.min(360, (hero?.offsetHeight ?? 720) * 0.5)
    floatingIndex?.classList.toggle('is-visible', indexVisible)
    floatingIndex?.setAttribute('aria-hidden', String(!indexVisible))
    const probe = window.innerHeight * 0.32
    let activeNode = ''
    progressNodes.forEach((node) => {
      const target = document.getElementById(node.dataset.progressNode ?? '')
      if (target && target.getBoundingClientRect().top <= probe)
        activeNode = node.dataset.progressNode ?? ''
    })
    progressNodes.forEach((node) => {
      if (node.dataset.progressNode === activeNode)
        node.setAttribute('aria-current', 'location')
      else node.removeAttribute('aria-current')
    })
  }
  updateScroll()
  window.addEventListener('scroll', updateScroll, { passive: true })

  const reducedMotion = window.matchMedia(
    '(prefers-reduced-motion: reduce)',
  ).matches
  const revealTargets = document.querySelectorAll<HTMLElement>('[data-reveal]')
  if (reducedMotion) {
    revealTargets.forEach((target) => target.classList.add('is-visible'))
  } else {
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            ;(entry.target as HTMLElement).classList.add('is-visible')
            revealObserver.unobserve(entry.target)
          }
        })
      },
      { rootMargin: '0px 0px -12% 0px', threshold: 0.08 },
    )
    revealTargets.forEach((target) => revealObserver.observe(target))
  }
  document.documentElement.classList.add('app-ready')

  const scope = document.querySelector<HTMLCanvasElement>('[data-signal-scope]')
  const scopeContext = scope?.getContext('2d')
  let scopeWidth = 0
  let scopeHeight = 0
  let scopeFrame = 0
  let scopeVisible = false

  const resizeScope = () => {
    if (!scope || !scopeContext) return
    const rect = scope.getBoundingClientRect()
    const density = Math.min(window.devicePixelRatio, 2)
    scopeWidth = Math.max(1, rect.width)
    scopeHeight = Math.max(1, rect.height)
    scope.width = Math.round(scopeWidth * density)
    scope.height = Math.round(scopeHeight * density)
    scopeContext.setTransform(density, 0, 0, density, 0, 0)
  }

  const drawScope = (time = 0) => {
    if (!scope || !scopeContext) return
    const ctx = scopeContext
    ctx.clearRect(0, 0, scopeWidth, scopeHeight)
    ctx.fillStyle = '#171b22'
    ctx.fillRect(0, 0, scopeWidth, scopeHeight)
    ctx.strokeStyle = 'rgba(242, 243, 245, 0.08)'
    ctx.lineWidth = 1
    for (let x = 0; x <= scopeWidth; x += 36) {
      ctx.beginPath()
      ctx.moveTo(x, 0)
      ctx.lineTo(x, scopeHeight)
      ctx.stroke()
    }
    for (let y = 0; y <= scopeHeight; y += 28) {
      ctx.beginPath()
      ctx.moveTo(0, y)
      ctx.lineTo(scopeWidth, y)
      ctx.stroke()
    }
    const colors = [
      '#0d9488',
      '#1c1917',
      '#78716c',
      '#0d9488',
      '#44403c',
      '#1c1917',
      '#78716c',
      '#0d9488',
    ]
    for (let channel = 0; channel < 8; channel += 1) {
      const baseY = ((channel + 0.5) / 8) * scopeHeight
      ctx.strokeStyle = colors[channel]
      ctx.globalAlpha = channel < 4 ? 0.95 : 0.58
      ctx.lineWidth = channel === 0 ? 1.8 : 1.1
      ctx.beginPath()
      for (let x = 0; x <= scopeWidth; x += 2) {
        const phase = x * (0.045 + channel * 0.003) + time * 0.0022
        const burst = Math.pow(
          Math.max(0, Math.sin(x * 0.012 + time * 0.0007 + channel)),
          5,
        )
        const wave =
          Math.sin(phase) * 2.2 +
          Math.sin(phase * 2.7) * burst * (6 + channel * 0.45)
        const y = baseY + wave
        if (x === 0) ctx.moveTo(x, y)
        else ctx.lineTo(x, y)
      }
      ctx.stroke()
    }
    ctx.globalAlpha = 1
    if (!reducedMotion && !document.hidden && scopeVisible)
      scopeFrame = requestAnimationFrame(drawScope)
  }

  if (scope && scopeContext) {
    resizeScope()
    const scopeResizeObserver = new ResizeObserver(resizeScope)
    scopeResizeObserver.observe(scope)
    if (reducedMotion) {
      drawScope(1400)
    } else {
      const scopeVisibilityObserver = new IntersectionObserver(
        (entries) => {
          scopeVisible = entries.some((entry) => entry.isIntersecting)
          cancelAnimationFrame(scopeFrame)
          if (scopeVisible && !document.hidden)
            scopeFrame = requestAnimationFrame(drawScope)
        },
        { rootMargin: '120px 0px', threshold: 0.01 },
      )
      scopeVisibilityObserver.observe(scope)
    }
    document.addEventListener('visibilitychange', () => {
      cancelAnimationFrame(scopeFrame)
      if (!document.hidden && !reducedMotion && scopeVisible)
        scopeFrame = requestAnimationFrame(drawScope)
    })
  }
</script>
