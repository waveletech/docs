---
import DeviceScene from './DeviceScene.astro'
import LongformSection from './LongformSection.astro'
import { getRelativeLocaleUrl } from 'astro:i18n'
import { translations, type Locale } from '../i18n/content'

interface Props {
  locale?: Locale
}

const { locale = 'en' } = Astro.props
const t = translations[locale]
const zhUrl = getRelativeLocaleUrl('zh')
const enUrl = getRelativeLocaleUrl('en')

const variants = [
  'variant.r8b',
  'variant.r8u',
  'variant.e6b',
  'variant.e6u',
  'variant.e12',
  'variant.e18',
]

const translated = (key: string) => ({ key })
const specRows = [
  {
    label: 'spec.transport',
    values: ['BLE', 'TYPE-C', 'BLE', 'TYPE-C', 'TYPE-C', 'TYPE-C'],
  },
  { label: 'spec.channels', values: ['8', '8', '6', '6', '12', '18'] },
  {
    label: 'spec.frontend',
    values: [
      'TI AFE',
      'TI AFE',
      'GALVANI W1',
      'GALVANI W1',
      'GALVANI W1',
      'GALVANI W1',
    ],
  },
  {
    label: 'spec.sample',
    values: [
      '250 SPS',
      '2000 SPS',
      '250 SPS',
      '2000 SPS',
      '2000 SPS',
      '2000 SPS',
    ],
  },
  {
    label: 'spec.bandwidth',
    values: [
      '0–63 HZ',
      '0–500 HZ',
      '0–125 HZ',
      '0–1000 HZ',
      '0–1000 HZ',
      '0–1000 HZ',
    ],
  },
  {
    label: 'spec.noise',
    values: [
      '5 µVPP @10–63',
      '10 µVPP @50–500',
      '5 µVPP @60–125',
      '10 µVPP @50–500',
      '10 µVPP @50–500',
      '10 µVPP @50–500',
    ],
  },
  {
    label: 'spec.imu',
    values: ['104 HZ', '208 HZ', '104 HZ', '208 HZ', '208 HZ', '208 HZ'],
  },
  {
    label: 'spec.haptic',
    values: [
      translated('common.no'),
      translated('common.no'),
      translated('common.yes'),
      translated('common.yes'),
      translated('common.no'),
      translated('common.no'),
    ],
  },
  {
    label: 'spec.module',
    values: [
      '55×40×12 MM',
      '55×40×12 MM',
      '25×36×14 MM',
      '25×36×14 MM',
      '56×47×15 MM',
      '56×47×15 MM',
    ],
  },
  {
    label: 'spec.runtime',
    values: [
      '18 H',
      '18 H',
      '4 H',
      '4 H',
      translated('common.external'),
      translated('common.external'),
    ],
  },
  {
    label: 'spec.price',
    values: ['980*', '1280*', '1000*', '1380*', '1800*', '2800*'],
  },
  {
    label: 'spec.status',
    values: [
      translated('common.sale'),
      translated('common.sale'),
      translated('common.reserve'),
      translated('common.reserve'),
      translated('common.pilot'),
      translated('common.pilot'),
    ],
  },
]

const packetExample = `{
  "seq": 1842,
  "t_us": 209341100,
  "emg": [302, 288, 417, 391, ...],
  "imu": { "acc": [0.18, -0.04, 0.97],
           "gyro": [12.4, -3.1, 0.8] },WL
  "contact": "ok"WL
}`
---

<DeviceScene />

<header
  class='site-header'
  data-header
>
  <a
    class='brand'
    href='#top'
    aria-label='W/L Biointerface'
  >
    <span class='brand-mark'>W/L</span>
    <span class='brand-line'>GALVANI<br />BIOINTERFACE</span>
  </a>
  <nav
    class='main-nav'
    aria-label={t['nav.label']}
    data-i18n-aria='nav.label'
  >
    <a
      href='#system'
      data-i18n='nav.system'
      >{t['nav.system']}</a
    >
    <a
      href='#variants'
      data-i18n='nav.variants'
      >{t['nav.variants']}</a
    >
    <a
      href='#signal'
      data-i18n='nav.signal'
      >{t['nav.signal']}</a
    >
    <a
      href='#pipeline'
      data-i18n='nav.pipeline'
      >{t['nav.pipeline']}</a
    >
    <a
      href='#protocols'
      data-i18n='nav.protocols'
      >{t['nav.protocols']}</a
    >
  </nav>
  <select
    class='mobile-index'
    aria-label={t['nav.label']}
    data-i18n-aria='nav.label'
    data-mobile-index
  >
    <option
      value=''
      data-i18n='nav.index'
      >{t['nav.index']}</option
    >
    <option
      value='#system'
      data-i18n='nav.system'
      >{t['nav.system']}</option
    >
    <option
      value='#variants'
      data-i18n='nav.variants'
      >{t['nav.variants']}</option
    >
    <option
      value='#signal'
      data-i18n='nav.signal'
      >{t['nav.signal']}</option
    >
    <option
      value='#pipeline'
      data-i18n='nav.pipeline'
      >{t['nav.pipeline']}</option
    >
    <option
      value='#protocols'
      data-i18n='nav.protocols'
      >{t['nav.protocols']}</option
    >
  </select>
  <div
    class='language-switch'
    role='group'
    aria-label={t['lang.label']}
    data-i18n-aria='lang.label'
  >
    <a
      href={zhUrl}
      aria-label={t['lang.zh']}
      data-i18n-aria='lang.zh'
      aria-current={locale === 'zh' ? 'page' : undefined}
      lang='zh-CN'
      >中</a
    >
    <a
      href={enUrl}
      aria-label={t['lang.en']}
      data-i18n-aria='lang.en'
      aria-current={locale === 'en' ? 'page' : undefined}
      lang='en'
      >EN</a
    >
  </div>
</header>

<div
  class='scroll-meter'
  aria-hidden='true'
>
  <span data-scroll-progress></span>
</div>

<nav
  class='floating-index'
  data-floating-index
  aria-label={t['nav.label']}
  data-i18n-aria='nav.label'
  aria-hidden='true'
>
  <div class='floating-index-links'>
    <a
      href='#system'
      data-progress-node='system'
      data-i18n='nav.system'
      >{t['nav.system']}</a
    >
    <a
      href='#variants'
      data-progress-node='variants'
      data-i18n='nav.variants'
      >{t['nav.variants']}</a
    >
    <a
      href='#signal'
      data-progress-node='signal'
      data-i18n='nav.signal'
      >{t['nav.signal']}</a
    >
    <a
      href='#motion'
      data-progress-node='motion'
      data-i18n='nav.motion'
      >{t['nav.motion']}</a
    >
    <a
      href='#mechanics'
      data-progress-node='mechanics'
      data-i18n='nav.mechanics'
      >{t['nav.mechanics']}</a
    >
    <a
      href='#pipeline'
      data-progress-node='pipeline'
      data-i18n='nav.pipeline'
      >{t['nav.pipeline']}</a
    >
    <a
      href='#protocols'
      data-progress-node='protocols'
      data-i18n='nav.protocols'
      >{t['nav.protocols']}</a
    >
  </div>
  <div
    class='floating-index-track'
    aria-hidden='true'
  >
    <span data-floating-progress></span>
  </div>
</nav>

<main id='top'>
  <section
    class='hero scene-section'
    data-scene='hero'
  >
    <div class='hero-copy'>
      <p
        class='eyebrow hero-eyebrow'
        data-i18n='hero.kicker'
      >
        {t['hero.kicker']}
      </p>
      <h1 data-i18n='hero.title'>{t['hero.title']}</h1>
      <p
        class='hero-lede'
        data-i18n='hero.lede'
      >
        {t['hero.lede']}
      </p>
      <p class='status-tag'>
        <span></span><b data-i18n='hero.tag'>{t['hero.tag']}</b>
      </p>
      <div class='hero-stats'>
        <div>
          <strong>18</strong><span data-i18n='hero.stat.channels'
            >{t['hero.stat.channels']}</span>
        </div>
        <div>
          <strong>2K <small>SPS</small></strong><span
            data-i18n='hero.stat.sample'>{t['hero.stat.sample']}</span>
        </div>
        <div>
          <strong>24 <small>BIT</small></strong><span
            data-i18n='hero.stat.depth'>{t['hero.stat.depth']}</span>
        </div>
      </div>
      <div
        class='hero-meta'
        aria-label={t['hero.specsLabel']}
        data-i18n-aria='hero.specsLabel'
      >
        <span data-i18n='hero.meta.frontend'>{t['hero.meta.frontend']}</span>
        <span data-i18n='hero.meta.motion'>{t['hero.meta.motion']}</span>
        <span data-i18n='hero.meta.fit'>{t['hero.meta.fit']}</span>
      </div>
    </div>
  </section>

  <section
    id='system'
    class='content-section scene-section system-section'
    data-scene='system'
  >
    <div
      class='content-column'
      data-reveal
    >
      <p
        class='eyebrow'
        data-i18n='system.eyebrow'
      >
        {t['system.eyebrow']}
      </p>
      <h2 data-i18n='system.title'>{t['system.title']}</h2>
      <p
        class='section-lede'
        data-i18n='system.body'
      >
        {t['system.body']}
      </p>
      <p
        class='callout-line'
        data-i18n='system.note'
      >
        {t['system.note']}
      </p>
      <LongformSection
        section='system'
        locale={locale}
      />
      <ol class='signal-chain'>
        <li>
          <span>01</span><b data-i18n='system.step.electrode'
            >{t['system.step.electrode']}</b>
        </li>
        <li>
          <span>02</span><b data-i18n='system.step.afe'
            >{t['system.step.afe']}</b>
        </li>
        <li>
          <span>03</span><b data-i18n='system.step.adc'
            >{t['system.step.adc']}</b>
        </li>
        <li>
          <span>04</span><b data-i18n='system.step.sync'
            >{t['system.step.sync']}</b>
        </li>
        <li>
          <span>05</span><b data-i18n='system.step.stream'
            >{t['system.step.stream']}</b>
        </li>
      </ol>
      <div class='sensor-stack'>
        <p
          class='micro-label'
          data-i18n='system.stack'
        >
          {t['system.stack']}
        </p>
        <ul>
          <li>
            <span>EMG</span><b data-i18n='system.stack.emg'
              >{t['system.stack.emg']}</b>
          </li>
          <li>
            <span>IMU</span><b data-i18n='system.stack.imu'
              >{t['system.stack.imu']}</b>
          </li>
          <li>
            <span>HPT</span><b data-i18n='system.stack.haptic'
              >{t['system.stack.haptic']}</b>
          </li>
          <li>
            <span>PWR</span><b data-i18n='system.stack.power'
              >{t['system.stack.power']}</b>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <section
    id='variants'
    class='wide-section variants-section scene-section'
    data-scene='variants'
  >
    <div
      class='wide-heading'
      data-reveal
    >
      <p
        class='eyebrow'
        data-i18n='variants.eyebrow'
      >
        {t['variants.eyebrow']}
      </p>
      <h2 data-i18n='variants.title'>{t['variants.title']}</h2>
      <p data-i18n='variants.body'>{t['variants.body']}</p>
    </div>
    <LongformSection
      section='variants'
      locale={locale}
    />
    <div
      class='table-scroll'
      tabindex='0'
      aria-label={t['variants.title']}
      data-i18n-aria='variants.title'
      data-reveal
    >
      <table class='spec-table'>
        <thead>
          <tr>
            <th>SPEC / NODE</th>
            {
              variants.map((key, index) => (
                <th>
                  <>
                    <span>0{index + 1}</span>
                    <b data-i18n={key}>{t[key]}</b>
                  </>
                </th>
              ))
            }
          </tr>
        </thead>
        <tbody>
          {
            specRows.map((row) => (
              <tr>
                <th data-i18n={row.label}>{t[row.label]}</th>
                {row.values.map((value) =>
                  typeof value === 'string' ? (
                    <td>{value}</td>
                  ) : (
                    <td data-i18n={value.key}>{t[value.key]}</td>
                  ),
                )}
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>

  <section
    id='signal'
    class='content-section scene-section signal-section'
    data-scene='signal'
  >
    <div
      class='content-column wide-copy'
      data-reveal
    >
      <p
        class='eyebrow'
        data-i18n='signal.eyebrow'
      >
        {t['signal.eyebrow']}
      </p>
      <h2 data-i18n='signal.title'>{t['signal.title']}</h2>
      <p
        class='section-lede'
        data-i18n='signal.body'
      >
        {t['signal.body']}
      </p>
    </div>
    <LongformSection
      section='signal'
      locale={locale}
    />
    <div
      class='scope-layout'
      data-reveal
    >
      <div class='scope-panel'>
        <div class='panel-heading'>
          <span data-i18n='signal.scope'>{t['signal.scope']}</span>
          <span data-i18n='signal.scope.note'>{t['signal.scope.note']}</span>
        </div>
        <canvas
          class='signal-scope'
          data-signal-scope
          aria-hidden='true'
        ></canvas>
        <div
          class='scope-channels'
          aria-hidden='true'
        >
          <span>CH 01</span><span>CH 04</span><span>CH 08</span><span
            >+001842</span>
        </div>
      </div>
      <div class='signal-metrics'>
        <div>
          <strong>5–10 <small>µVPP</small></strong><span
            data-i18n='signal.metric.noise'>{t['signal.metric.noise']}</span>
        </div>
        <div>
          <strong>0–1K <small>HZ</small></strong><span
            data-i18n='signal.metric.band'>{t['signal.metric.band']}</span>
        </div>
        <div>
          <strong>&lt; 1 <small>SAMPLE</small></strong><span
            data-i18n='signal.metric.sync'>{t['signal.metric.sync']}</span>
        </div>
      </div>
    </div>
    <div
      class='feature-row'
      data-reveal
    >
      <article>
        <span>01</span><h3 data-i18n='signal.feature.raw'>
          {t['signal.feature.raw']}
        </h3><p data-i18n='signal.feature.raw.body'>
          {t['signal.feature.raw.body']}
        </p>
      </article>
      <article>
        <span>02</span><h3 data-i18n='signal.feature.filter'>
          {t['signal.feature.filter']}
        </h3><p data-i18n='signal.feature.filter.body'>
          {t['signal.feature.filter.body']}
        </p>
      </article>
      <article>
        <span>03</span><h3 data-i18n='signal.feature.guard'>
          {t['signal.feature.guard']}
        </h3><p data-i18n='signal.feature.guard.body'>
          {t['signal.feature.guard.body']}
        </p>
      </article>
    </div>
  </section>

  <section
    id='motion'
    class='content-section scene-section motion-section'
    data-scene='motion'
  >
    <div class='motion-grid'>
      <div data-reveal>
        <p
          class='eyebrow'
          data-i18n='motion.eyebrow'
        >
          {t['motion.eyebrow']}
        </p>
        <h2 data-i18n='motion.title'>{t['motion.title']}</h2>
        <p
          class='section-lede'
          data-i18n='motion.body'
        >
          {t['motion.body']}
        </p>
      </div>
      <div
        class='imu-panel'
        data-reveal
      >
        <div class='panel-heading'>
          <span data-i18n='motion.caption'>{t['motion.caption']}</span><span
            >IMU / 208 HZ</span>
        </div>
        <div
          class='axis-visual'
          aria-hidden='true'
        >
          <div class='axis-ring ring-a'></div><div class='axis-ring ring-b'>
          </div><div class='axis-core'>XYZ</div>
        </div>
        <div class='imu-readouts'>
          <div>
            <span data-i18n='motion.accel'>{t['motion.accel']}</span><b
              >X +0.18 G</b
            ><b>Y −0.04 G</b><b>Z +0.97 G</b>
          </div>
          <div>
            <span data-i18n='motion.gyro'>{t['motion.gyro']}</span><b
              >R +12.4°</b
            ><b>P −03.1°</b><b>Y +00.8°</b>
          </div>
          <div>
            <span data-i18n='motion.fusion'>{t['motion.fusion']}</span><b
              >ΔT 0.48 MS</b
            ><b>SEQ 01842</b><b>LOCKED</b>
          </div>
        </div>
      </div>
    </div>
    <LongformSection
      section='motion'
      locale={locale}
    />
  </section>

  <section
    id='mechanics'
    class='wide-section mechanics-section scene-section'
    data-scene='mechanics'
  >
    <div
      class='mechanics-heading'
      data-reveal
    >
      <p
        class='eyebrow'
        data-i18n='mechanics.eyebrow'
      >
        {t['mechanics.eyebrow']}
      </p>
      <h2 data-i18n='mechanics.title'>{t['mechanics.title']}</h2>
      <p data-i18n='mechanics.body'>{t['mechanics.body']}</p>
    </div>
    <LongformSection
      section='mechanics'
      locale={locale}
    />
    <div
      class='wearability-strip'
      data-reveal
    >
      <div>
        <strong>25 <small>MM</small></strong><span data-i18n='mechanics.width'
          >{t['mechanics.width']}</span>
      </div>
      <div>
        <strong>≈3 <small>MM</small></strong><span
          data-i18n='mechanics.thickness'>{t['mechanics.thickness']}</span>
      </div>
      <div>
        <strong>14–22 <small>CM</small></strong><span data-i18n='mechanics.fit'
          >{t['mechanics.fit']}</span>
      </div>
      <div>
        <strong>S / M / L</strong><span data-i18n='mechanics.material'
          >{t['mechanics.material']}</span>
      </div>
    </div>
    <div
      class='product-gallery'
      data-reveal
    >
      <figure>
        <div class='image-well'>
          <img
            src='/images/research-band.png'
            alt={t['gallery.research.alt']}
            data-i18n-alt='gallery.research.alt'
            loading='lazy'
          />
        </div>
        <figcaption>
          <b data-i18n='gallery.research'>{t['gallery.research']}</b><span
            data-i18n='gallery.research.body'
            >{t['gallery.research.body']}</span>
        </figcaption>
      </figure>
      <figure>
        <div class='image-well'>
          <img
            src='/images/embodied-6-band.png'
            alt={t['gallery.embodied6.alt']}
            data-i18n-alt='gallery.embodied6.alt'
            loading='lazy'
          />
        </div>
        <figcaption>
          <b data-i18n='gallery.embodied6'>{t['gallery.embodied6']}</b><span
            data-i18n='gallery.embodied6.body'
            >{t['gallery.embodied6.body']}</span>
        </figcaption>
      </figure>
      <figure>
        <div class='image-well'>
          <img
            src='/images/embodied-18-band.png'
            alt={t['gallery.embodied18.alt']}
            data-i18n-alt='gallery.embodied18.alt'
            loading='lazy'
          />
        </div>
        <figcaption>
          <b data-i18n='gallery.embodied18'>{t['gallery.embodied18']}</b><span
            data-i18n='gallery.embodied18.body'
            >{t['gallery.embodied18.body']}</span>
        </figcaption>
      </figure>
    </div>
  </section>

  <section
    id='pipeline'
    class='content-section scene-section pipeline-section'
    data-scene='pipeline'
  >
    <div
      class='pipeline-intro'
      data-reveal
    >
      <p
        class='eyebrow'
        data-i18n='pipeline.eyebrow'
      >
        {t['pipeline.eyebrow']}
      </p>
      <h2 data-i18n='pipeline.title'>{t['pipeline.title']}</h2>
      <p
        class='section-lede'
        data-i18n='pipeline.body'
      >
        {t['pipeline.body']}
      </p>
    </div>
    <LongformSection
      section='pipeline'
      locale={locale}
    />
    <div class='pipeline-grid'>
      <ol
        class='workflow'
        data-reveal
      >
        <li>
          <span>01</span><div>
            <b data-i18n='pipeline.step.connect'>{t['pipeline.step.connect']}</b
            ><p data-i18n='pipeline.step.connect.body'>
              {t['pipeline.step.connect.body']}
            </p>
          </div>
        </li>
        <li>
          <span>02</span><div>
            <b data-i18n='pipeline.step.check'>{t['pipeline.step.check']}</b><p
              data-i18n='pipeline.step.check.body'
            >
              {t['pipeline.step.check.body']}
            </p>
          </div>
        </li>
        <li>
          <span>03</span><div>
            <b data-i18n='pipeline.step.zero'>{t['pipeline.step.zero']}</b><p
              data-i18n='pipeline.step.zero.body'
            >
              {t['pipeline.step.zero.body']}
            </p>
          </div>
        </li>
        <li>
          <span>04</span><div>
            <b data-i18n='pipeline.step.capture'>{t['pipeline.step.capture']}</b
            ><p data-i18n='pipeline.step.capture.body'>
              {t['pipeline.step.capture.body']}
            </p>
          </div>
        </li>
        <li>
          <span>05</span><div>
            <b data-i18n='pipeline.step.pack'>{t['pipeline.step.pack']}</b><p
              data-i18n='pipeline.step.pack.body'
            >
              {t['pipeline.step.pack.body']}
            </p>
          </div>
        </li>
      </ol>
      <div
        class='packet-panel'
        data-reveal
      >
        <div class='panel-heading'>
          <span data-i18n='pipeline.packet'>{t['pipeline.packet']}</span><span
            >24 BIT / CRC OK</span>
        </div>
        <pre><code>{packetExample}</code></pre>
        <div class='transport-modes'>
          <div>
            <b data-i18n='pipeline.ble'>{t['pipeline.ble']}</b><span
              data-i18n='pipeline.ble.body'>{t['pipeline.ble.body']}</span>
          </div>
          <div>
            <b data-i18n='pipeline.usb'>{t['pipeline.usb']}</b><span
              data-i18n='pipeline.usb.body'>{t['pipeline.usb.body']}</span>
